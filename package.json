{
  "name": "adition-electric",
  "version": "10.5.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=adition-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build && node -e \"import('fs').then(fs=>fs.writeFileSync('dist/_routes.json',JSON.stringify({version:1,include:['/*'],exclude:['/','/index.html','/manifest.json','/static/*','/sw.js','/favicon.svg','/favicon.ico']})))\"",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name adition-electric"
  },
  "dependencies": {
    "hono": "^4.12.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@hono/vite-cloudflare-pages": "^0.4.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
